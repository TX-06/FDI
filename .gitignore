__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.DS_Store
*.swp
.venv/

# Per-image FDI analysis visualizations (regenerated by running the analyzer)
output/
output/*_fdi_analysis.png
output/*_red_mask.png
output/*_garment_roi.png
output/*_distorted_binary_mask.png

# Manuscript-rendering and temporary QA outputs
output/docx_render*/
output/jti_*render*/
output/*render*/
tmp_web/
tmp_docx_images/
tmp_docx_logic_check/
tmp_metric_rationale_render/

# Human-rating and perception-study files are intentionally not released
output/*human*rating*
output/*perception*

# Third-party public VTON crops and source screenshots are not redistributed
test_images/real_vton_public_sources/
test_images/real_vton_public_stripes/
test_images/real_vton_stableviton/
output/real_vton_public_stripes/
output/public_real_vton_stripe_panel*.png
output/*crop_qa*.png
output/*source_cropbox*.png

# Third-party real photos and local scratch inputs
test_images/pexels_*.jpg
test_images/unsplash_*.jpg
test_images/my_test*

# Manuscript binaries are submitted separately, not tracked in the public data repo
docs/*.docx
docs/*.pdf
output/pdf/
